#!/usr/bin/env python3

import json
import os
import selectors
import socket
import struct
import sys
import time


def _socket_name() -> str:
    return "hyprland-zen-bridge.sock"


def _default_runtime_dir() -> str | None:
    runtime = os.environ.get("XDG_RUNTIME_DIR")
    if runtime:
        return runtime
    guess = f"/run/user/{os.getuid()}"
    if os.path.isdir(guess):
        return guess
    return None


def _dedup_paths(paths: list[str]) -> list[str]:
    seen: set[str] = set()
    out: list[str] = []
    for path in paths:
        if not path:
            continue
        norm = os.path.abspath(path)
        if norm in seen:
            continue
        seen.add(norm)
        out.append(norm)
    return out


def resolve_socket_candidates() -> list[str]:
    custom = os.environ.get("HYPRLAND_ZEN_SOCKET")
    if custom:
        return [os.path.abspath(custom)]
    runtime_env = os.environ.get("XDG_RUNTIME_DIR")
    runtime_default = f"/run/user/{os.getuid()}"
    candidates = []
    if runtime_env:
        candidates.append(os.path.join(runtime_env, _socket_name()))
    if os.path.isdir(runtime_default):
        candidates.append(os.path.join(runtime_default, _socket_name()))
    candidates.append(f"/tmp/hyprland-zen-bridge-{os.getuid()}.sock")
    return _dedup_paths(candidates)


def resolve_socket_path() -> str:
    custom = os.environ.get("HYPRLAND_ZEN_SOCKET")
    if custom:
        return os.path.abspath(custom)
    runtime = _default_runtime_dir()
    if runtime:
        return os.path.join(runtime, _socket_name())
    return f"/tmp/hyprland-zen-bridge-{os.getuid()}.sock"


def encode_json_line(payload: dict) -> bytes:
    return (json.dumps(payload, separators=(",", ":")) + "\n").encode("utf-8")


def write_native_message(payload: dict) -> None:
    body = json.dumps(payload, separators=(",", ":")).encode("utf-8")
    sys.stdout.buffer.write(struct.pack("<I", len(body)))
    sys.stdout.buffer.write(body)
    sys.stdout.buffer.flush()


def emit_line(payload: dict) -> None:
    sys.stdout.write(json.dumps(payload, separators=(",", ":")) + "\n")
    sys.stdout.flush()


class NativeAdapter:
    def __init__(self) -> None:
        self.selector = selectors.DefaultSelector()
        self.stdin_fd = sys.stdin.fileno()
        os.set_blocking(self.stdin_fd, False)
        self.selector.register(self.stdin_fd, selectors.EVENT_READ, "stdin")
        self.socket_paths = resolve_socket_candidates()
        self.socket_path = self.socket_paths[0]
        self.socket_path_index = 0
        self.sock: socket.socket | None = None
        self.last_connect_attempt = 0.0
        self.stdin_buffer = bytearray()
        self.socket_buffer = ""
        self.pending_lines: list[bytes] = []

    def close_socket(self) -> None:
        if self.sock is None:
            return
        try:
            self.selector.unregister(self.sock)
        except Exception:
            pass
        try:
            self.sock.close()
        except OSError:
            pass
        self.sock = None
        self.socket_buffer = ""

    def try_connect_socket(self) -> None:
        if self.sock is not None:
            return
        now = time.monotonic()
        if now - self.last_connect_attempt < 1.0:
            return
        self.last_connect_attempt = now
        if not self.socket_paths:
            self.socket_paths = [resolve_socket_path()]
        count = len(self.socket_paths)
        start = self.socket_path_index % count
        for offset in range(count):
            idx = (start + offset) % count
            path = self.socket_paths[idx]
            sock = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
            try:
                sock.connect(path)
            except OSError:
                sock.close()
                continue
            sock.setblocking(False)
            self.sock = sock
            self.socket_path = path
            self.socket_path_index = (idx + 1) % count
            self.selector.register(sock, selectors.EVENT_READ, "socket")
            self.flush_pending()
            return
        self.socket_path_index = (start + 1) % count

    def queue_line(self, line: bytes) -> None:
        self.pending_lines.append(line)
        if len(self.pending_lines) > 256:
            self.pending_lines = self.pending_lines[-256:]

    def flush_pending(self) -> None:
        if self.sock is None:
            return
        while self.pending_lines:
            line = self.pending_lines[0]
            try:
                self.sock.sendall(line)
            except OSError:
                self.close_socket()
                return
            self.pending_lines.pop(0)

    def ensure_socket_alive(self) -> None:
        if self.sock is None:
            return
        try:
            probe = self.sock.recv(1, socket.MSG_PEEK | socket.MSG_DONTWAIT)
        except BlockingIOError:
            return
        except OSError:
            self.close_socket()
            return
        if probe == b"":
            self.close_socket()

    def process_native_stdin(self, data: bytes) -> bool:
        if not data:
            return False
        self.stdin_buffer.extend(data)
        while len(self.stdin_buffer) >= 4:
            msg_len = struct.unpack("<I", self.stdin_buffer[:4])[0]
            if len(self.stdin_buffer) < 4 + msg_len:
                break
            payload_bytes = bytes(self.stdin_buffer[4 : 4 + msg_len])
            del self.stdin_buffer[: 4 + msg_len]
            try:
                payload = json.loads(payload_bytes.decode("utf-8"))
            except (UnicodeDecodeError, json.JSONDecodeError):
                continue
            line = encode_json_line(payload)
            if self.sock is None:
                self.queue_line(line)
                continue
            try:
                self.sock.sendall(line)
            except OSError:
                self.close_socket()
                self.queue_line(line)
        return True

    def process_socket_data(self, data: bytes) -> None:
        if not data:
            self.close_socket()
            return
        self.socket_buffer += data.decode("utf-8", errors="replace")
        while "\n" in self.socket_buffer:
            raw_line, self.socket_buffer = self.socket_buffer.split("\n", 1)
            raw_line = raw_line.strip()
            if not raw_line:
                continue
            try:
                payload = json.loads(raw_line)
            except json.JSONDecodeError:
                continue
            write_native_message(payload)

    def run(self) -> int:
        try:
            while True:
                self.try_connect_socket()
                self.ensure_socket_alive()
                events = self.selector.select(timeout=0.25)
                if not events:
                    self.flush_pending()
                    continue
                for key, _ in events:
                    tag = key.data
                    if tag == "stdin":
                        try:
                            data = os.read(self.stdin_fd, 8192)
                        except BlockingIOError:
                            continue
                        if not self.process_native_stdin(data):
                            return 0
                    elif tag == "socket":
                        assert self.sock is not None
                        try:
                            data = self.sock.recv(8192)
                        except BlockingIOError:
                            continue
                        except OSError:
                            self.close_socket()
                            continue
                        self.process_socket_data(data)
                self.flush_pending()
        finally:
            self.close_socket()


class LineBridgeServer:
    def __init__(self) -> None:
        self.socket_path = resolve_socket_path()
        self.listener = self.bind_listener(self.socket_path)
        self.selector = selectors.DefaultSelector()
        self.selector.register(sys.stdin, selectors.EVENT_READ, "stdin")
        self.selector.register(self.listener, selectors.EVENT_READ, "listener")
        self.browser_conn: socket.socket | None = None
        self.browser_buffer = ""
        self.bridge_connected = False
        self.pending_ops: list[tuple[float, dict]] = []
        self.pending_max = 64
        self.pending_ttl_seconds = 8.0

    def bind_listener(self, path: str) -> socket.socket:
        parent = os.path.dirname(path)
        if parent:
            os.makedirs(parent, exist_ok=True)
        if os.path.exists(path):
            probe = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
            try:
                probe.connect(path)
            except OSError:
                try:
                    os.unlink(path)
                except OSError:
                    pass
            else:
                raise SystemExit(f"hyprland-zen-native-host already running at {path}")
            finally:
                probe.close()
        listener = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
        listener.bind(path)
        listener.listen(1)
        listener.setblocking(False)
        return listener

    def emit_bridge_state(self, connected: bool, reason: str) -> None:
        if self.bridge_connected == connected:
            return
        self.bridge_connected = connected
        emit_line({
            "type": "bridge-state",
            "connected": connected,
            "reason": reason,
            "socket": self.socket_path,
        })

    def queue_op(self, payload: dict) -> int:
        now = time.monotonic()
        self.pending_ops.append((now, payload))
        if len(self.pending_ops) > self.pending_max:
            self.pending_ops = self.pending_ops[-self.pending_max :]
        return len(self.pending_ops)

    def prune_pending_ops(self) -> None:
        if not self.pending_ops:
            return
        cutoff = time.monotonic() - self.pending_ttl_seconds
        self.pending_ops = [item for item in self.pending_ops if item[0] >= cutoff]

    def flush_pending_ops(self) -> None:
        if self.browser_conn is None:
            return
        self.prune_pending_ops()
        while self.pending_ops:
            _, payload = self.pending_ops[0]
            try:
                self.browser_conn.sendall(encode_json_line(payload))
            except OSError:
                self.close_connection("browser-send-failed")
                return
            self.pending_ops.pop(0)

    def close_connection(self, reason: str = "browser-disconnected") -> None:
        if self.browser_conn is None:
            return
        try:
            self.selector.unregister(self.browser_conn)
        except Exception:
            pass
        try:
            self.browser_conn.close()
        except OSError:
            pass
        self.browser_conn = None
        self.browser_buffer = ""
        self.emit_bridge_state(False, reason)

    def run(self) -> int:
        try:
            self.emit_bridge_state(False, "startup")
            while True:
                for key, _ in self.selector.select(timeout=0.5):
                    tag = key.data
                    if tag == "stdin":
                        line = sys.stdin.readline()
                        if line == "":
                            return 0
                        line = line.strip()
                        if not line:
                            continue
                        try:
                            payload = json.loads(line)
                        except json.JSONDecodeError as err:
                            emit_line({"type": "error", "op": "decode", "message": str(err)})
                            continue
                        if self.browser_conn is None:
                            qlen = self.queue_op(payload)
                            emit_line({
                                "type": "queued",
                                "op": str(payload.get("op", "")),
                                "message": f"browser-bridge-not-connected (socket={self.socket_path})",
                                "queued": True,
                                "queue_length": qlen,
                                "socket": self.socket_path,
                            })
                            continue
                        try:
                            self.browser_conn.sendall(encode_json_line(payload))
                        except OSError:
                            qlen = self.queue_op(payload)
                            self.close_connection("browser-send-failed")
                            emit_line({
                                "type": "queued",
                                "op": str(payload.get("op", "")),
                                "message": f"browser-bridge-disconnected (socket={self.socket_path})",
                                "queued": True,
                                "queue_length": qlen,
                                "socket": self.socket_path,
                            })
                    elif tag == "listener":
                        conn, _ = self.listener.accept()
                        conn.setblocking(False)
                        self.close_connection("browser-replaced")
                        self.browser_conn = conn
                        self.browser_buffer = ""
                        self.selector.register(self.browser_conn, selectors.EVENT_READ, "browser")
                        self.emit_bridge_state(True, "browser-connected")
                        self.flush_pending_ops()
                    elif tag == "browser":
                        assert self.browser_conn is not None
                        try:
                            data = self.browser_conn.recv(4096)
                        except OSError:
                            data = b""
                        if not data:
                            self.close_connection("browser-eof")
                            continue
                        self.browser_buffer += data.decode("utf-8", errors="replace")
                        while "\n" in self.browser_buffer:
                            raw_line, self.browser_buffer = self.browser_buffer.split("\n", 1)
                            raw_line = raw_line.strip()
                            if not raw_line:
                                continue
                            try:
                                payload = json.loads(raw_line)
                            except json.JSONDecodeError as err:
                                emit_line({"type": "error", "op": "decode", "message": str(err)})
                                continue
                            emit_line(payload)
        finally:
            self.close_connection("shutdown")
            try:
                self.selector.unregister(self.listener)
            except Exception:
                pass
            self.listener.close()
            try:
                os.unlink(self.socket_path)
            except OSError:
                pass


def main() -> int:
    if "--line-stdio" in sys.argv[1:]:
        return LineBridgeServer().run()
    if sys.stdin.isatty():
        raise SystemExit(
            "hyprland-zen-native-host: native adapter mode is launched by browser; "
            "do not run manually in a terminal"
        )
    return NativeAdapter().run()


if __name__ == "__main__":
    raise SystemExit(main())
