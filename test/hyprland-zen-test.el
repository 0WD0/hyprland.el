(ert-deftest hyprland-zen-test-ensure-tabs-ready/retries-after-bridge-recovers ()
  (let ((hyprland-zen--tabs (make-hash-table :test #'equal))
        (hyprland-zen--process 'proc)
        (hyprland-zen--bridge-connected nil)
        (wait-calls 0)
        refresh-count)
    (cl-letf (((symbol-function 'hyprland-zen-running-p)
               (lambda () t))
              ((symbol-function 'hyprland-zen-refresh)
               (lambda () (setq refresh-count (1+ (or refresh-count 0)))))
              ((symbol-function 'hyprland-zen-refresh-workspaces)
               #'ignore)
              ((symbol-function 'hyprland-zen--wait-for-tabs)
               (lambda (&optional _timeout)
                 (setq wait-calls (1+ wait-calls))
                 (if (= wait-calls 1)
                     nil
                   '(((tab_id . "42"))))))
              ((symbol-function 'hyprland-zen--wait-for-bridge)
               (lambda (&optional _timeout)
                 (setq hyprland-zen--bridge-connected t)
                 t)))
      (should (equal (hyprland-zen--ensure-tabs-ready)
                     '(((tab_id . "42")))))
      (should (= wait-calls 2))
      (should (= refresh-count 2)))))

