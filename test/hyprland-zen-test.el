(ert-deftest hyprland-zen-test-status/reports-current-diagnostics ()
  (let ((hyprland-zen--process 'proc)
        (hyprland-zen--tabs (make-hash-table :test #'equal))
        (hyprland-zen--workspaces (make-hash-table :test #'equal))
        (hyprland-zen--messages-in 5)
        (hyprland-zen--messages-out 7)
        (hyprland-zen--trace '((:ts 1.0 :dir out :payload ((op . "list-tabs")))))
        (hyprland-zen--last-line-type "snapshot")
        (hyprland-zen--last-error-message "none")
        report)
    (puthash "zen/default/1" '((tab_id . "1")) hyprland-zen--tabs)
    (puthash "zen/default/w" '((workspace_id . "w")) hyprland-zen--workspaces)
    (cl-letf (((symbol-function 'process-live-p)
               (lambda (proc) (eq proc 'proc)))
              ((symbol-function 'process-id)
               (lambda (_proc) 4242))
              ((symbol-function 'hyprland-zen--seconds-since)
               (lambda (_timestamp) 0.5)))
      (setq report (hyprland-zen-status)))
    (should (plist-get report :running))
    (should (= (plist-get report :pid) 4242))
    (should (= (plist-get report :tab-count) 1))
    (should (= (plist-get report :workspace-count) 1))
    (should (= (plist-get report :messages-in) 5))
    (should (= (plist-get report :messages-out) 7))
    (should (= (plist-get report :trace-count) 1))
    (should (equal (plist-get report :last-message-type) "snapshot"))))

(ert-deftest hyprland-zen-test-doctor/returns-readiness-report ()
  (let (started refreshed refreshed-workspaces)
    (cl-letf (((symbol-function 'hyprland-zen-running-p)
               (lambda () nil))
              ((symbol-function 'hyprland-zen-start)
               (lambda () (setq started t)))
              ((symbol-function 'hyprland-zen-refresh)
               (lambda () (setq refreshed t)))
              ((symbol-function 'hyprland-zen-refresh-workspaces)
               (lambda () (setq refreshed-workspaces t)))
              ((symbol-function 'hyprland-zen--wait-for-tabs)
               (lambda (&optional _timeout) '(((tab_id . "1")))))
              ((symbol-function 'hyprland-zen--ensure-workspaces-ready)
               (lambda () '(((workspace_id . "w")))))
              ((symbol-function 'hyprland-zen-status)
               (lambda () '(:running t :tab-count 1 :workspace-count 1))))
      (let ((report (hyprland-zen-doctor 2.0)))
        (should started)
        (should refreshed)
        (should refreshed-workspaces)
        (should (= (plist-get report :wait-time) 2.0))
        (should (plist-get report :tabs-ready))
        (should (plist-get report :workspaces-ready))
        (should (plist-get report :running))))))

