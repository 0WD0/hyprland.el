(ert-deftest hyprland-zen-test-apply-message/bridge-state-and-queued-updates-metrics ()
  (let ((hyprland-zen--bridge-connected nil)
        (hyprland-zen--bridge-last-reason nil)
        (hyprland-zen--queued-op-count 0)
        (hyprland-zen--last-queued-op nil))
    (hyprland-zen--apply-message
     '((type . "bridge-state")
       (connected . t)
       (reason . "browser-bridge-connected")))
    (should hyprland-zen--bridge-connected)
    (should (equal hyprland-zen--bridge-last-reason "browser-bridge-connected"))
    (hyprland-zen--apply-message
     '((type . "queued")
       (op . "open-url")
       (queue_length . 3)
       (message . "browser-bridge-not-connected")))
    (should-not hyprland-zen--bridge-connected)
    (should (= hyprland-zen--queued-op-count 3))
    (should (equal hyprland-zen--last-queued-op "open-url"))))

