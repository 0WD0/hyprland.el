        (hyprland-zen--process nil)
        launched refreshed refreshed-workspaces)
    (cl-letf (((symbol-function 'make-process)
               (lambda (&rest args)
                 (setq launched args)
                 'proc))
              ((symbol-function 'process-live-p)
               (lambda (proc) (eq proc 'proc)))
              ((symbol-function 'accept-process-output)
               (lambda (&rest _args) t))
              ((symbol-function 'hyprland-zen--resolve-host-command)
               (lambda () '("host" "--stdio")))
              ((symbol-function 'hyprland-zen-refresh)
               (lambda () (setq refreshed t)))
              ((symbol-function 'hyprland-zen-refresh-workspaces)
               (lambda () (setq refreshed-workspaces t))))
      (should (eq (hyprland-zen-start) 'proc))
      (should (equal (plist-get launched :command) '("host" "--stdio")))
      (should refreshed)
      (should refreshed-workspaces))))

(ert-deftest hyprland-zen-test-start/retries-after-socket-conflict ()
  (let ((hyprland-zen-host-command '("host" "--stdio"))
        (hyprland-zen-auto-refresh-on-start nil)
        (hyprland-zen-recover-startup-socket-conflict t)
        (hyprland-zen--process nil)
        (starts 0)
        recovered)
    (cl-letf (((symbol-function 'hyprland-zen--start-process)
               (lambda (_resolved)
                 (setq starts (1+ starts))
                 (if (= starts 1) 'dead-proc 'proc)))
              ((symbol-function 'hyprland-zen--resolve-host-command)
               (lambda () '("host" "--stdio")))
              ((symbol-function 'hyprland-zen-running-p)
               (lambda () (eq hyprland-zen--process 'proc)))
              ((symbol-function 'accept-process-output)
               (lambda (&rest _args) t))
              ((symbol-function 'hyprland-zen--socket-conflict-detected-p)
               (lambda () t))
              ((symbol-function 'hyprland-zen--recover-startup-socket-conflict)
               (lambda () (setq recovered t) t)))
      (should (eq (hyprland-zen-start) 'proc))
      (should recovered)
      (should (= starts 2)))))

